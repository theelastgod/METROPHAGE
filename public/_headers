# Cloudflare Pages — HTML always revalidated; hashed /assets/* long-cache (immutable).
# version.json is the deploy detector for long-lived tabs (must never be cached).
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/version.json
  Cache-Control: public, max-age=0, must-revalidate
/assets/*
  Cache-Control: public, max-age=31536000, immutable
