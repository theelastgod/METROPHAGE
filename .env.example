# METROPHAGE — environment template. Copy to `.env.local` and fill in as needed.
# Real .env files are gitignored; this committed template documents the knobs.

# ── $METRO on-chain layer (Phase 5) ─────────────────────────────────────────
# EMPTY by default — the game runs fully on the off-chain soft currency with no
# crypto. Set VITE_METRO_MINT only AFTER server secrets are live (see MAINNET_GO_LIVE.md).
# Pre-CA: leave blank. After pump.fun: paste the mint address.
VITE_METRO_MINT=

# Target cluster: devnet (default) | mainnet-beta. Mainnet is never implicit.
VITE_METRO_CLUSTER=devnet

# Optional client RPC override (defaults to public cluster endpoint).
# VITE_METRO_RPC=https://api.mainnet-beta.solana.com

# Real-value mainnet additionally requires this explicit arm flag (set to 1) so a
# stray/mistaken mint can never silently move real money. Leave empty until counsel
# has signed off AND a real CA is in hand. Requires matching server METRO_MAINNET_ARMED=1.
VITE_METRO_MAINNET_ARMED=

# ── client → server ─────────────────────────────────────────────────────────
# Online (Phase 4) server URL. Defaults to the local wrangler dev address.
# Production: wss://metrophage-server.wendellphillips.workers.dev/ws
VITE_SERVER_URL=
