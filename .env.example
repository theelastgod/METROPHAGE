# METROPHAGE — environment template. Copy to `.env.local` and fill in as needed.
# Real .env files are gitignored; this committed template documents the knobs.

# ── $METRO on-chain layer (Solana SPL primary) ──────────────────────────────
# EMPTY by default — the game runs fully on off-chain credits with no crypto.
# When you have the mint CA:
#   1) Server FIRST (wrangler secrets): METRO_MINT (base58), METRO_TREASURY_SECRET
#      (base64 64-byte Solana keypair), optional METRO_RPC. Deploy the Worker.
#   2) Then set VITE_METRO_MINT to the same base58 mint and rebuild the client.
# Never ship VITE_METRO_MINT before server secrets (sim would trust deposits).
VITE_METRO_MINT=

# Target cluster: mainnet-beta (default) | devnet (rehearsal only).
VITE_METRO_CLUSTER=mainnet-beta

# Optional client RPC override (defaults to the Solana mainnet-beta public endpoint,
# which is rate-limited — point this at a dedicated RPC before launch).
# VITE_METRO_RPC=https://api.mainnet-beta.solana.com

# Force settlement family (default solana). Use robinhood only for the dormant
# ERC-20 alternate; it also needs VITE_METRO_CHAIN_ID / an EVM RPC.
# VITE_METRO_SETTLEMENT=solana

# Real-value bridge on mainnet requires this arm flag (set to 1) together with a real CA.
# Leave empty while awaiting the contract address. Requires matching server METRO_MAINNET_ARMED=1.
VITE_METRO_MAINNET_ARMED=

# ── WalletConnect (mobile MetaMask / Phantom / Rainbow / Trust / …) ─────────
# Free project ID from https://dashboard.reown.com (create project → Project ID).
# Public client id — safe to bake into the browser build. Without it, desktop
# extensions still work; mobile falls back to "open in MetaMask" deep-links only.
VITE_WALLETCONNECT_PROJECT_ID=

# ── client → server ─────────────────────────────────────────────────────────
# Online (Phase 4) server URL. Defaults to the local wrangler dev address.
# Production: wss://metrophage-server.wendellphillips.workers.dev/ws
VITE_SERVER_URL=
