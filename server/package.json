{
  "name": "metrophage-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "METROPHAGE authoritative game server — Cloudflare Worker + Durable Objects + D1",
  "scripts": {
    "dev": "wrangler dev",
    "dev:sim": "wrangler dev --var METRO_ALLOW_SIM:1",
    "migrate:local": "wrangler d1 migrations apply metrophage --local",
    "migrate:remote": "wrangler d1 migrations apply metrophage --remote",
    "stamp": "node scripts/stamp-build.mjs",
    "deploy": "node scripts/stamp-build.mjs && wrangler deploy",
    "smoke": "node scripts/smoke.mjs",
    "smoke:load": "node scripts/smoke.mjs load",
    "smoke:prod": "node scripts/prod-smoke.mjs",
    "smoke:launch": "node scripts/smoke.mjs launch && node scripts/smoke.mjs death && node scripts/smoke.mjs reconnect && node scripts/smoke.mjs stash",
    "smoke:pvp-escrow": "node scripts/pvp-escrow-smoke.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260623.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.103.0"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bigint-buffer": "file:vendor/bigint-buffer-1.1.6.tgz",
    "ethers": "^6.17.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
