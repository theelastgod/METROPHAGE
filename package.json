{
  "name": "metrophage",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "METROPHAGE — top-down neon-noir cyberpunk action-RPG (Phase 0 vertical slice)",
  "scripts": {
    "dev": "vite",
    "dev:online": "sh -c 'npm run dev -- --host 127.0.0.1 --port 5174 & cd server && npm run dev -- --port 8787; wait'",
    "build": "tsc --noEmit && vite build",
    "build:production": "node tools/release-client.mjs --build-only",
    "deploy:client": "node tools/release-client.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:trusted": "cd server && node scripts/smoke.mjs move && node scripts/smoke.mjs combat && node scripts/smoke.mjs kit && node scripts/smoke.mjs quest && node scripts/smoke.mjs abuse",
    "smoke:load": "cd server && node scripts/smoke.mjs load",
    "smoke:panels": "node tools/panel-smoke.mjs",
    "scan:dead": "node tools/dead-code-scan.mjs",
    "sim:economy": "node tools/economy-sim.mjs",
    "report:economy": "node tools/economy-report.mjs",
    "gen:music": "node tools/gen-music.mjs",
    "gen:music:local": "node tools/gen-music-local.mjs"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "playwright": "^1.49.0",
    "sharp": "^0.35.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
